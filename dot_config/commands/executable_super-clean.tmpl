#!/usr/bin/env bash
# super-clean —— Distro-specific system cleanup script.
# Currently supports Arch Linux and derivatives.

set -euo pipefail

{{ if ne .chezmoi.os "linux" -}}
echo "super-clean is only supported on Linux" >&2
exit 1
{{ else if not (hasKey .chezmoi.osRelease "id") -}}
echo "super-clean: unable to detect Linux distribution" >&2
exit 1
{{ else if or (eq .chezmoi.osRelease.id "arch") (eq .chezmoi.osRelease.id "manjaro") (eq .chezmoi.osRelease.id "endeavouros") -}}
KEEP=2
DRY_RUN=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        -n|--dry-run) DRY_RUN=1 ;;
        *) echo "Unknown option: $1" >&2; exit 2 ;;
    esac
    shift
done

run() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        echo "  [dry-run] $*"
    else
        "$@"
    fi
}

echo "=== [0/3] Environment check ==="
for cmd in pacman sudo paccache yay; do
    if command -v "$cmd" >/dev/null 2>&1; then
        echo "  [OK]      $cmd -> $(command -v "$cmd")"
    else
        echo "  [MISSING] $cmd"
    fi
done
if ! command -v pacman >/dev/null 2>&1; then
    echo "FATAL: pacman is required. Aborting." >&2
    exit 1
fi

echo ""
echo "=== [1/3] Removing orphan packages ==="
orphans=$(pacman -Qdtq 2>/dev/null) || orphans=""
if [[ -n "$orphans" ]]; then
    run sudo pacman -Rns --noconfirm $orphans
else
    echo "No orphan packages found."
fi

echo ""
echo "=== [2/3] Cleaning pacman cache with paccache (keeping last $KEEP versions) ==="
if command -v paccache >/dev/null 2>&1; then
    run sudo paccache -rk"$KEEP" || true
    echo "-- Removing all cached versions of uninstalled packages --"
    run sudo paccache -ruk0 || true
else
    echo "paccache not found. Install pacman-contrib: sudo pacman -S pacman-contrib"
fi

echo ""
echo "=== [3/3] Cleaning yay AUR build cache (pacman cache untouched) ==="
if command -v yay >/dev/null 2>&1; then
    run yay -Sc --aur --noconfirm
else
    echo "yay not found, skipping AUR cache cleanup."
fi

echo ""
echo "=== Cleanup complete ==="
{{ else -}}
echo "super-clean is not supported on {{ .chezmoi.osRelease.id }}" >&2
exit 1
{{ end -}}
